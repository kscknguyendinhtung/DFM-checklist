{
  "entities": {
    "Project": {
      "title": "DFM Project",
      "description": "A DFM check project for a specific part or tooling.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project or part name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "ownerId": { "type": "string", "description": "UID of the user who created the project" },
        "status": { "type": "string", "enum": ["in-progress", "completed"], "description": "Current status of the check" }
      },
      "required": ["name", "createdAt", "ownerId", "status"]
    },
    "ChecklistItem": {
      "title": "Checklist Item",
      "description": "A master checklist item for DFM tooling.",
      "type": "object",
      "properties": {
        "item": { "type": "string", "description": "Category (e.g., 1. Basic Info)" },
        "subItem": { "type": "string", "description": "Sub-category (e.g., Resin)" },
        "checkPoint": { "type": "string", "description": "What to check" },
        "standard": { "type": "string", "description": "The standard to meet" }
      },
      "required": ["item", "subItem", "checkPoint", "standard"]
    },
    "CheckResult": {
      "title": "Check Result",
      "description": "The result of a specific checklist item for a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "ID of the project" },
        "checklistItemId": { "type": "string", "description": "ID of the master checklist item" },
        "status": { "type": "string", "enum": ["OK", "NG", "N/A"], "description": "Result of the check" },
        "remark": { "type": "string", "description": "User comments or notes" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" },
        "markers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "type": { "type": "string", "enum": ["OK", "NG"] },
              "page": { "type": "number" }
            }
          }
        }
      },
      "required": ["projectId", "checklistItemId", "status", "updatedAt"]
    },
    "LessonLearned": {
      "title": "Lesson Learned",
      "description": "A suggestion or lesson learned from previous DFM checks.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Brief summary of the lesson" },
        "content": { "type": "string", "description": "Detailed description or standard update" },
        "category": { "type": "string", "description": "Related DFM category" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "authorId": { "type": "string", "description": "UID of the user who added the lesson" }
      },
      "required": ["title", "content", "category", "createdAt", "authorId"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of DFM projects"
    },
    "/checklist_items/{itemId}": {
      "schema": "ChecklistItem",
      "description": "Master checklist items"
    },
    "/projects/{projectId}/results/{resultId}": {
      "schema": "CheckResult",
      "description": "Results for a specific project"
    },
    "/lessons_learned/{lessonId}": {
      "schema": "LessonLearned",
      "description": "Lessons learned and standard updates"
    }
  }
}
